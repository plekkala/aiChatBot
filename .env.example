# ─── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostgreSQL + pgvector ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=doc_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# ─── App Settings ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production

# ─── Chunking Settings ────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ─── LLM Settings ─────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=1024
